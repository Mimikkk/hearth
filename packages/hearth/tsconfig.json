{
  "compilerOptions": {
    "baseUrl": ".",
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "ESNext",
    "target": "ESNext",
    "allowJs": true,
    "noImplicitAny": true,
    "moduleResolution": "NodeNext",
    "allowImportingTsExtensions": true,
    "importHelpers": true,
    "isolatedModules": true,
    "strictNullChecks": true,
    "lib": [
      "DOM",
      "ESNext",
      "es2015.proxy"
    ],
    "types": [
      "vite/client"
    ]
  },
  "include": [
    "./node_modules/@webgpu/types",
    "declarations",
    "src"
  ],
  "references": [
    {
      "path": "./tsconfig.vite.json"
    }
  ]
}
