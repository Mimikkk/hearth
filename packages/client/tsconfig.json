{
  "compilerOptions": {
    "baseUrl": ".",
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "ESNext",
    "target": "ESNext",
    "allowJs": true,
    "noImplicitAny": true,
    "moduleResolution": "NodeNext",
    "allowImportingTsExtensions": true,
    "importHelpers": true,
    "isolatedModules": true,
    "strictNullChecks": true,
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "lib": [
      "DOM",
      "ESNext"
    ],
    "types": [
      "vite/client"
    ],
    "typeRoots": [
      "./node_modules/@types"
    ],
    "paths": {
      "@shared/*": [
        "src/shared/*"
      ],
      "@modules/*": [
        "src/modules/*"
      ],
      "@logic/*": [
        "src/shared/logic/*"
      ],
      "@components/*": [
        "src/shared/components/*"
      ],
      "@utils/*": [
        "src/shared/utils/*"
      ]
    }
  },
  "include": [
    "../../node_modules/@webgpu/types",
    "declarations",
    "assets",
    "src"
  ],
  "references": [
    {
      "path": "./tsconfig.vite.json"
    }
  ]
}
